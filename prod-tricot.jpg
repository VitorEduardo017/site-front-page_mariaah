<script>
// ── CURSOR MAGNÉTICO ──
const cur = document.getElementById('cur');
const cur2 = document.getElementById('cur2');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{
  mx=e.clientX;my=e.clientY;
  cur.style.left=mx+'px';cur.style.top=my+'px';
});
(function loop(){
  rx+=(mx-rx)*.1;ry+=(my-ry)*.1;
  cur2.style.left=rx+'px';cur2.style.top=ry+'px';
  requestAnimationFrame(loop);
})();
document.querySelectorAll('a,button,.cat,.pc,.n-icon,.fcart').forEach(el=>{
  el.addEventListener('mouseenter',()=>{cur.classList.add('h');cur2.classList.add('h')});
  el.addEventListener('mouseleave',()=>{cur.classList.remove('h');cur2.classList.remove('h')});
});

// ── NAV SCROLL ──
window.addEventListener('scroll',()=>{
  document.getElementById('nav').classList.toggle('s',scrollY>80);
});

// ── SCROLL REVEAL ──
const obs = new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){e.target.classList.add('on');obs.unobserve(e.target);}
  });
},{threshold:.08});
document.querySelectorAll('.rv,.rv2,.rv3').forEach(el=>obs.observe(el));

// ── FILTER PRODUTOS ──
function filterProds(btn, cat){
  document.querySelectorAll('.pf').forEach(b=>b.classList.remove('a'));
  btn.classList.add('a');
  document.querySelectorAll('#pGrid .pc').forEach(pc=>{
    const pcCat = pc.dataset.cat;
    pc.style.display = (cat==='todos'||pcCat===cat) ? '' : 'none';
  });
}

// ── TAMANHOS ──
document.querySelectorAll('.p-sizes').forEach(psz=>{
  psz.querySelectorAll('.sz:not(.x)').forEach(sz=>{
    sz.addEventListener('click',()=>{
      psz.querySelectorAll('.sz').forEach(s=>s.classList.remove('a'));
      sz.classList.add('a');
    });
  });
});
</script>
</body>
